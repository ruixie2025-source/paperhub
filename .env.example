# Application
# Recommended: development, 1.0.0, INFO, backend/logs
APP_ENVIRONMENT=
APP_VERSION=
LOG_LEVEL=
LOG_DIR=

# Local persistence paths (Docker Compose overrides these with mounted paths)
# Recommended: backend/paperhub.db, backend/uploads, backend/chroma,
# backend/model-cache
DATABASE_PATH=
UPLOAD_DIR=
CHROMA_DIR=
MODEL_CACHE_DIR=

# AI provider
# Recommended: deepseek, deepseek-v4-flash
AI_PROVIDER=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_BASE_URL=
DEEPSEEK_TIMEOUT_SECONDS=
DEEPSEEK_MAX_RETRIES=
DEEPSEEK_RETRY_BACKOFF_SECONDS=

# Embedding and PDF processing
# Recommended: BAAI/bge-m3, 50 MB, 60 seconds, 1 retry
EMBEDDING_MODEL=
UPLOAD_MAX_MB=
PDF_PARSE_TIMEOUT_SECONDS=
PDF_PARSE_RETRIES=

# Rate limiting
# Recommended: 5/minute, 30/minute, 10/minute, memory://
UPLOAD_RATE_LIMIT=
CHAT_RATE_LIMIT=
ANALYSIS_RATE_LIMIT=
RATE_LIMIT_STORAGE_URI=

# HTTP security
# Recommended locally: false, localhost,127.0.0.1,testserver
TRUST_PROXY_HEADERS=
ALLOWED_HOSTS=
CORS_ORIGINS=
HEALTHCHECK_DEEPSEEK_NETWORK=
HEALTHCHECK_TIMEOUT_SECONDS=

# Vite development proxy; production uses same-origin Nginx routing
VITE_DEV_API_TARGET=

# Docker Compose and Nginx
HTTP_PORT=
NGINX_HTPASSWD_FILE=
